{
  "name": "express-typescript-boilerplate",
  "version": "1.0.14",
  "description": "An Express boilerplate backend",
  "author": "Edwin Hernandez",
  "repository": "edwinhern/express-typescript-2024",
  "license": "MIT",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "build": "tsc && tsup",
    "start:dev:collector": "node --import=tsx --watch src/collectorApp.ts",
    "start:dev:consumer": "node --import=tsx --watch src/consumerApp.ts",
    "start:dev:query": "node --import=tsx --watch src/queryApp.ts",
    "start:collector": "node dist/collectorApp.js",
    "start:consumer": "node dist/consumerApp.js",
    "start:query": "node dist/queryApp.js",
    "dev:metrics:generator": "node --import=tsx src/scripts/generateMetrics.ts",
    "dev:sqs:buffer": "node --import=tsx src/scripts/sqsBufferWorker.ts",
    "check": "biome check --write",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma reset",
    "prisma:migrate:prod": "prisma migrate deploy"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.3.4",
    "@aws-sdk/client-sqs": "^3.1009.0",
    "cors": "2.8.5",
    "dotenv": "17.2.1",
    "express": "5.1.0",
    "express-rate-limit": "8.0.1",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "ioredis": "^5.10.0",
    "kysely": "^0.28.11",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "pino": "9.9.0",
    "pino-http": "10.5.0",
    "swagger-ui-express": "5.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.4",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/luxon": "^3.7.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "6.0.3",
    "@types/swagger-ui-express": "4.1.8",
    "@vitest/coverage-v8": "3.2.4",
    "pino-pretty": "13.1.1",
    "prettier": "3.8.1",
    "prisma": "^7.4.2",
    "supertest": "7.1.4",
    "tsup": "8.5.0",
    "tsx": "4.20.4",
    "typescript": "5.9.2",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4"
  },
  "tsup": {
    "entry": [
      "src/collectorApp.ts",
      "src/consumerApp.ts",
      "src/queryApp.ts"
    ],
    "outDir": "dist",
    "format": [
      "cjs"
    ],
    "target": "es2020",
    "sourcemap": true,
    "clean": true,
    "dts": true,
    "splitting": false,
    "skipNodeModulesBundle": true
  },
  "packageManager": "pnpm@10.14.0"
}
