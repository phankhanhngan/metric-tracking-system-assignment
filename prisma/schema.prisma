generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Metric data points tracked per user.
/// Managed as a TimescaleDB hypertable (see migration SQL).
model Metric {
  id             BigInt   @id @default(autoincrement())
  user_id        String   @db.Uuid
  type           String   @db.VarChar(255)
  date           DateTime @db.Timestamptz()
  value          Decimal  @db.Decimal(10, 2)
  original_value Decimal  @db.Decimal(10, 2)
  original_unit  String   @db.VarChar(20)
  created_at     DateTime @default(now()) @db.Timestamptz()

  @@index([user_id, type, date(sort: Desc)], name: "idx_metrics_user_type_date")
  @@map("metrics")
}
